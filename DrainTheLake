local Rayfield = loadstring(game:HttpGet("https://sirius.menu/rayfield"))()

local ReplicatedStorage = game:GetService("ReplicatedStorage")

local BucketUsed = ReplicatedStorage.VerdantRemotes["VDT_Bucket.Used"]
local BucketPoured = ReplicatedStorage.VerdantRemotes["VDT_Bucket.Poured"]
local TokensTake = ReplicatedStorage.VerdantRemotes["VDT_Tokens.Take"]
local ChestOpen = ReplicatedStorage.VerdantRemotes["VDT_Chest.Open"]

local player = game.Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local rootPart = character:WaitForChild("HumanoidRootPart")

player.CharacterAdded:Connect(function(char)
    character = char
    rootPart = char:WaitForChild("HumanoidRootPart")
end)

local Window = Rayfield:CreateWindow({
    Name = "Drain The Lake",
    LoadingTitle = "Loading...",
    LoadingSubtitle = "Drac's Creation",
    ConfigurationSaving = {
        Enabled = false
    }
})

local Tab = Window:CreateTab("Main", 4483362458)

local autoCollectWater = false
local autoPourWater = false
local autoCollectToken = false
local autoOpenChest = false

local function getClosestPrompt(maxDistance)
    local closestPrompt = nil
    local shortestDistance = maxDistance or 25

    if not rootPart or not workspace:FindFirstChild("Scripted") then
        return nil
    end

    for _, obj in ipairs(workspace.Scripted:GetDescendants()) do
        if obj:IsA("ProximityPrompt") and obj.Parent and obj.Parent.Name == "ProximityPosition" then
            local distance = (rootPart.Position - obj.Parent.Position).Magnitude

            if distance < shortestDistance then
                shortestDistance = distance
                closestPrompt = obj
            end
        end
    end

    return closestPrompt
end

Tab:CreateToggle({
    Name = "Auto Collect Water",
    CurrentValue = false,
    Flag = "CollectWater",
    Callback = function(Value)
        autoCollectWater = Value

        if Value then
            task.spawn(function()
                while autoCollectWater do
                    pcall(function()
                        BucketUsed:FireServer()
                    end)
                    task.wait(0.15)
                end
            end)
        end
    end
})

Tab:CreateToggle({
    Name = "Auto Pour Water",
    CurrentValue = false,
    Flag = "PourWater",
    Callback = function(Value)
        autoPourWater = Value

        if Value then
            task.spawn(function()
                while autoPourWater do
                    local prompt = getClosestPrompt(30)

                    if prompt then
                        pcall(function()
                            BucketPoured:FireServer(prompt)
                        end)
                    end

                    task.wait(0.2)
                end
            end)
        end
    end
})

Tab:CreateToggle({
    Name = "Auto Collect Token",
    CurrentValue = false,
    Flag = "CollectToken",
    Callback = function(Value)
        autoCollectToken = Value

        if Value then
            task.spawn(function()
                while autoCollectToken do
                    local prompt = getClosestPrompt(30)

                    if prompt then
                        pcall(function()
                            TokensTake:FireServer(prompt)
                        end)
                    end

                    task.wait(0.2)
                end
            end)
        end
    end
})

Tab:CreateToggle({
    Name = "Auto Open Chests",
    CurrentValue = false,
    Flag = "OpenChests",
    Callback = function(Value)
        autoOpenChest = Value

        if Value then
            task.spawn(function()
                while autoOpenChest do
                    pcall(function()
                        for _, chest in ipairs(workspace.Scripted.Chests:GetChildren()) do
                            if chest:FindFirstChild("Part") then
                                ChestOpen:FireServer(chest.Part)
                            end
                        end
                    end)

                    task.wait(0.5)
                end
            end)
        end
    end
})
