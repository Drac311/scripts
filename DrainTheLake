-- Loop to continuously enforce WalkSpeed and prevent game overrides
task.spawn(function()
    while true do
        if human and human.WalkSpeed ~= targetSpeed then
            pcall(function()
                human.WalkSpeed = targetSpeed
            end)
        end
        task.wait(0.1)
    end
end)

-- Standard Infinite Jump Implementation
UserInputService.JumpRequest:Connect(function()
    if infJump and human and rootPart then
        human:ChangeState(Enum.HumanoidStateType.Jumping)
        rootPart.Velocity = Vector3.new(rootPart.Velocity.X, human.JumpPower, rootPart.Velocity.Z)
    end
end)

-- GUI Dragging Logic
local dragging, dragInput, dragStart, startPos
MainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dragging = false end
        end)
    end
end)
MainFrame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and input == dragInput then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
