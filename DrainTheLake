-- Helper function to create buttons
local function createButton(name, color, callback)
    local Btn = Instance.new("TextButton")
    Btn.Size = UDim2.new(1, -20, 0, 38)
    Btn.BackgroundColor3 = color
    Btn.Text = name
    Btn.TextColor3 = Color3.new(1,1,1)
    Btn.TextSize = 11
    Btn.Font = Enum.Font.GothamBold
    Btn.Parent = Scroll
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 6)
    btnCorner.Parent = Btn
    
    Btn.MouseButton1Click:Connect(function()
        callback(Btn)
    end)
    return Btn
end

-- Helper function for textbox inputs
local function createTextBox(placeholder, callback)
    local Box = Instance.new("TextBox")
    Box.Size = UDim2.new(1, -20, 0, 32)
    Box.BackgroundColor3 = Color3.fromRGB(30, 30, 45)
    Box.PlaceholderText = placeholder
    Box.PlaceholderColor3 = Color3.fromRGB(120, 120, 140)
    Box.Text = ""
    Box.TextColor3 = Color3.new(1,1,1)
    Box.TextSize = 11
    Box.Font = Enum.Font.Gotham
    Box.Parent = Scroll
    
    local boxCorner = Instance.new("UICorner")
    boxCorner.CornerRadius = UDim.new(0, 6)
    boxCorner.Parent = Box
    
    Box.FocusLost:Connect(function(enterPressed)
        if enterPressed then callback(Box.Text) end
    end)
    return Box
end

-- ULTIMATE PROMPT FINDER
local function getClosestPrompt(maxDistance)
    local closestPrompt = nil
    local shortestDistance = maxDistance or 25
    
    if not rootPart or not workspace:FindFirstChild("Scripted") then return nil end
    
    local allDescendants = workspace.Scripted:GetDescendants()
    
    for _, obj in ipairs(allDescendants) do
        if obj:IsA("ProximityPrompt") then
            if obj.Parent and obj.Parent.Name == "ProximityPosition" then
                local distance = (rootPart.Position - obj.Parent.Position).Magnitude
                if distance < shortestDistance then
                    shortestDistance = distance
                    closestPrompt = obj
                end
            end
        end
    end
    
    return closestPrompt
end

